{
  "manifest_version": 3,
  "name": "SafeSearch AI",
  "version": "1.0",
  "description": "AI-powered assistant that detects and redacts sensitive information in search queries.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.bing.com/*",
    "*://*.duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*",
        "*://*.bing.com/*",
        "*://*.duckduckgo.com/*"
      ],
      "css": ["src/content/content.css"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "SafeSearch AI Settings"
  }
}
